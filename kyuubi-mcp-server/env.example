# Kyuubi MCP Server 配置示例
# 复制此文件为 .env 并填入实际配置

# Kyuubi 服务器配置
KYUUBI_HOST=localhost
KYUUBI_PORT=10009
KYUUBI_DATABASE=default

# 认证配置
# 可选值: NONE, PLAIN, CUSTOM, LDAP, KERBEROS
KYUUBI_AUTH_TYPE=NONE
KYUUBI_USERNAME=
KYUUBI_PASSWORD=

# 客户端类型配置（新增）⭐
# 可选值: pyhive, jaydebeapi
# - pyhive: 轻量级，直接使用 Thrift 协议，无需 Java 环境
# - jaydebeapi: 功能完整，通过 JDBC 连接，需要 Java 环境和 JDBC 驱动
# 默认: jaydebeapi
KYUUBI_CLIENT_TYPE=jaydebeapi

# JDBC 驱动路径（仅当使用 jaydebeapi 时必需）
# 如果使用 pyhive，可以不设置此项
# 可以指定多个 JAR 文件，用逗号分隔
# 示例: /path/to/kyuubi-hive-jdbc-shaded.jar,/path/to/hadoop-common.jar
KYUUBI_JDBC_DRIVER_PATH=/path/to/kyuubi-hive-jdbc-shaded.jar

# 可选：日志级别
# LOG_LEVEL=INFO

